# Copy this file to .env and fill in the keys you'll actually use.
# gapeval_eval/judge.py and run_eval.py auto-load .env from this directory (or any parent).

# Default judge provider (gemini-2.5-flash) -- get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Only needed if you pass --judge_provider openai (gpt-5-mini)
OPENAI_API_KEY=

# Where model weights (Qwen2.5, SigLIP, show-o2 checkpoints) get cached. Defaults to
# show-o2/hf_cache/ if left blank -- set this only if you want a different location
# (e.g. a shared cache drive across multiple projects).
# HF_HOME=
